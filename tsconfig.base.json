{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@monolegal/shared": ["packages/shared/src/index.ts"],
      "@monolegal/domain": ["packages/domain/src/index.ts"],
      "@monolegal/application": ["packages/application/src/index.ts"],
      "@monolegal/infrastructure": ["packages/infrastructure/src/index.ts"]
    }
  }
}
