{
  "name": "monolegal-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de automatización de notificaciones de facturación - Reto Monolegal",
  "scripts": {
    "postinstall": "npm ci --prefix apps/frontend",
    "build": "npm run build:dotnet && npm run build --prefix apps/frontend",
    "build:dotnet": "dotnet build backend/dotnet/Monolegal.sln",
    "test": "dotnet test backend/dotnet/Monolegal.sln",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check && npm run build && npm test",
    "diagrams": "node scripts/fix-diagrams.mjs",
    "seed": "dotnet run --project backend/dotnet/src/Monolegal.Seed",
    "dev:api": "dotnet run --project backend/dotnet/src/Monolegal.Api",
    "dev:worker": "dotnet run --project backend/dotnet/src/Monolegal.Worker",
    "dev:frontend": "npm run dev --prefix apps/frontend"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
